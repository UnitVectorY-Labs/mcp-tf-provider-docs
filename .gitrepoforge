name: mcp-tf-provider-docs
default_branch: main
config:
  description: "A configurable MCP server that indexes and serves Terraform/Tofu provider documentation from a local Git repo to power accurate, context-aware code generation."
  license: MIT
  language: go
  release: release-go
  justfile: true
  codecov:
    enabled: true
  docs:
    enabled: false